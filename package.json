{
  "name": "vayna",
  "version": "1.0.0",
  "description": "VAYNA - Journal de Trading Professionnel",
  "main": "dist-electron/main.js",
  "author": "VAYNA",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && npm run copy:preload && concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:vite": "vite",
    "build": "npm run build:vite && npm run build:electron && npm run copy:preload",
    "build:vite": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "copy:preload": "node -e \"require('fs').copyFileSync('electron/preload-loader.cjs','dist-electron/preload-loader.cjs')\"",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "npm run build:electron && electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/cli": "^6.1.1",
    "@capacitor/core": "^6.1.1",
    "@capacitor/splash-screen": "^6.0.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@supabase/supabase-js": "^2.101.1",
    "@types/papaparse": "^5.5.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "express": "^4.18.2",
    "framer-motion": "^11.3.0",
    "jimp": "^0.22.10",
    "lucide-react": "^0.446.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.39",
    "supabase": "^2.84.10",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
